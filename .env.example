# ---------------------------------------------------------------------------
# SupplyScope environment configuration
# Copy this file to .env.local and fill in the keys you have.
# The app runs without any keys (agents return demo data), and each key you
# add turns on a real capability.
# ---------------------------------------------------------------------------

# Firecrawl — powers live market research (web search + competitor extraction).
# Get one at https://www.firecrawl.dev . Without it, agents return demo data.
FIRECRAWL_API_KEY=fc-your-key-here

# Anthropic — powers the Claude "Classifier" (category/keywords, vision-aware)
# and "Strategy Analyst" (positioning, differentiation, pricing, next steps).
# Without it those two agents are skipped; the rest still run.
# Get one at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here
# Optional — override the analysis model.
# ANTHROPIC_MODEL=

# Apify — powers the "Online Stores" agent (Amazon: brands, prices, ratings)
# and "China Suppliers" agent (AliExpress: wholesale prices, order volume).
# Without it, those two agents are skipped.
# Get one at https://console.apify.com
APIFY_API_TOKEN=apify_api_your-token-here

# Supabase — persistence + integration with the shared Retail-supply-intel DB.
# When set, ideas persist to Postgres and research fans out into the shared
# product_categories / suppliers / competitors / insights / snapshots tables.
# Without it, the app falls back to a local JSON file store (.data/db.json).
# Use the SERVICE-ROLE key (server-side only) — the tables have RLS enabled.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Access gate — HTTP Basic Auth for the public deployment (see middleware.ts).
# When BASIC_AUTH_PASSWORD is set, every page and API route requires these
# credentials, so unauthenticated visitors can't trigger DB writes or API spend.
# On Vercel, if no password is set the deployment fails closed (503) by design.
# Leave unset for local development (the app stays open locally).
BASIC_AUTH_USER=supplyscope
BASIC_AUTH_PASSWORD=
